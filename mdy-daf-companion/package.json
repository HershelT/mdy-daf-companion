{
  "name": "mdy-daf-companion-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Runtime for the MDY Daf Companion Claude Code plugin.",
  "bin": {
    "mdy-daf": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "npm run build && node --test \"dist/test/**/*.test.js\"",
    "validate:plugin": "claude plugin validate .",
    "check": "npm run test && npm run validate:plugin"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

